---
import { SITE } from 'astrowind:config';
import studioLogo from '~/assets/images/matyas-web-studio-logo-light.svg';

const logoSrc = typeof studioLogo === 'string' ? studioLogo : studioLogo.src;
---

<img
  src={logoSrc}
  alt={SITE?.name ?? 'Matyas Web Studio'}
  width="208"
  height="80"
  class="self-center h-12 md:h-12 w-auto ml-2 rtl:ml-0 rtl:mr-2"
  loading="eager"
  decoding="async"
/>
