---
export interface Props {
  locale?: 'hu' | 'en' | 'de';
}

const { locale = 'hu' } = Astro.props;

const webhookUrl = import.meta.env.PUBLIC_TWENTY_WEBHOOK_URL || '';
const formId = `twenty-contact-form-${locale}`;
const statusId = `twenty-contact-status-${locale}`;

const copy = {
  hu: {
    firstName: 'Keresztnév',
    lastName: 'Vezetéknév',
    email: 'E-mail',
    phone: 'Telefonszám (opcionális)',
    company: 'Cégnév (opcionális)',
    website: 'Weboldal URL (opcionális)',
    service: 'Miben segíthetünk?',
    servicePlaceholder: 'Válassz szolgáltatást',
    services: [
      'Weboldal fejlesztés',
      'Weboldal karbantartás',
      'CRM rendszer',
      'Automatizálás',
      'Marketing támogatás',
      'Egyéb',
    ],
    message: 'Projektleírás',
    messagePlaceholder: 'Írd le röviden a céljaidat, jelenlegi helyzetedet és határidődet.',
    consent: 'Elfogadom, hogy az adataimat kapcsolatfelvétel céljából kezeljétek.',
    submit: 'Ajánlatot kérek',
    sending: 'Küldés folyamatban...',
    success: 'Köszönjük! Az üzenetedet megkaptuk, hamarosan jelentkezünk.',
    error: 'Sikertelen küldés. Kérlek próbáld újra, vagy írj közvetlenül e-mailt.',
    webhookMissing: 'Az űrlap nincs teljesen bekötve. Hiányzik a PUBLIC_TWENTY_WEBHOOK_URL környezeti változó.',
  },
  en: {
    firstName: 'First name',
    lastName: 'Last name',
    email: 'Email',
    phone: 'Phone (optional)',
    company: 'Company (optional)',
    website: 'Website URL (optional)',
    service: 'How can we help?',
    servicePlaceholder: 'Select a service',
    services: ['Website development', 'Website maintenance', 'CRM system', 'Automation', 'Marketing support', 'Other'],
    message: 'Project details',
    messagePlaceholder: 'Briefly describe your goals, current setup, and timeline.',
    consent: 'I consent to my data being processed for contact and proposal purposes.',
    submit: 'Request a quote',
    sending: 'Sending...',
    success: 'Thank you! We received your message and will get back to you shortly.',
    error: 'Submission failed. Please try again or contact us by email.',
    webhookMissing: 'The form is not fully configured yet. PUBLIC_TWENTY_WEBHOOK_URL is missing.',
  },
  de: {
    firstName: 'Vorname',
    lastName: 'Nachname',
    email: 'E-Mail',
    phone: 'Telefon (optional)',
    company: 'Unternehmen (optional)',
    website: 'Website-URL (optional)',
    service: 'Wobei können wir helfen?',
    servicePlaceholder: 'Leistung auswählen',
    services: [
      'Webentwicklung',
      'Website-Wartung',
      'CRM-System',
      'Automatisierung',
      'Marketing-Unterstützung',
      'Sonstiges',
    ],
    message: 'Projektbeschreibung',
    messagePlaceholder: 'Beschreiben Sie kurz Ihre Ziele, aktuelle Situation und den Zeitrahmen.',
    consent: 'Ich stimme der Verarbeitung meiner Daten zur Kontaktaufnahme zu.',
    submit: 'Angebot anfragen',
    sending: 'Wird gesendet...',
    success: 'Vielen Dank! Ihre Nachricht wurde gesendet. Wir melden uns zeitnah.',
    error: 'Senden fehlgeschlagen. Bitte erneut versuchen oder per E-Mail kontaktieren.',
    webhookMissing: 'Das Formular ist noch nicht vollständig konfiguriert. PUBLIC_TWENTY_WEBHOOK_URL fehlt.',
  },
}[locale];
const isHungarian = locale === 'hu';
---

<div class="mx-auto mt-8 max-w-2xl text-left">
  {
    !webhookUrl && (
      <p class="mb-4 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert">
        {copy.webhookMissing}
      </p>
    )
  }

  <form id={formId} class="space-y-4" novalidate>
    <input type="hidden" name="locale" value={locale} />
    <input type="hidden" name="source" value="website_contact_form" />
    <input type="hidden" name="pagePath" value={Astro.url.pathname} />

    <div class="hidden" aria-hidden="true">
      <label for={`${formId}-contact-web`}>Website</label>
      <input id={`${formId}-contact-web`} name="contactWebsiteTrap" type="text" tabindex="-1" autocomplete="off" />
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        isHungarian ? (
          <>
            <div>
              <label for={`${formId}-last-name`} class="mb-1 block text-sm font-medium text-default">
                {copy.lastName}
              </label>
              <input
                id={`${formId}-last-name`}
                name="last_name"
                type="text"
                required
                autocomplete="family-name"
                class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for={`${formId}-first-name`} class="mb-1 block text-sm font-medium text-default">
                {copy.firstName}
              </label>
              <input
                id={`${formId}-first-name`}
                name="first_name"
                type="text"
                required
                autocomplete="given-name"
                class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
              />
            </div>
          </>
        ) : (
          <>
            <div>
              <label for={`${formId}-first-name`} class="mb-1 block text-sm font-medium text-default">
                {copy.firstName}
              </label>
              <input
                id={`${formId}-first-name`}
                name="first_name"
                type="text"
                required
                autocomplete="given-name"
                class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
              />
            </div>
            <div>
              <label for={`${formId}-last-name`} class="mb-1 block text-sm font-medium text-default">
                {copy.lastName}
              </label>
              <input
                id={`${formId}-last-name`}
                name="last_name"
                type="text"
                required
                autocomplete="family-name"
                class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
              />
            </div>
          </>
        )
      }
    </div>

    <div>
      <label for={`${formId}-email`} class="mb-1 block text-sm font-medium text-default">{copy.email}</label>
      <input
        id={`${formId}-email`}
        name="email"
        type="email"
        required
        autocomplete="email"
        class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
      />
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label for={`${formId}-phone`} class="mb-1 block text-sm font-medium text-default">{copy.phone}</label>
        <input
          id={`${formId}-phone`}
          name="phone"
          type="tel"
          autocomplete="tel"
          class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
        />
      </div>

      <div>
        <label for={`${formId}-company`} class="mb-1 block text-sm font-medium text-default">{copy.company}</label>
        <input
          id={`${formId}-company`}
          name="company"
          type="text"
          autocomplete="organization"
          class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
        />
      </div>
    </div>

    <div>
      <label for={`${formId}-website`} class="mb-1 block text-sm font-medium text-default">{copy.website}</label>
      <input
        id={`${formId}-website`}
        name="website"
        type="url"
        inputmode="url"
        placeholder="https://"
        autocomplete="url"
        class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
      />
    </div>

    <div>
      <label for={`${formId}-service`} class="mb-1 block text-sm font-medium text-default">{copy.service}</label>
      <select
        id={`${formId}-service`}
        name="service"
        required
        class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
      >
        <option value="" disabled selected>{copy.servicePlaceholder}</option>
        {copy.services.map((service) => <option value={service}>{service}</option>)}
      </select>
    </div>

    <div>
      <label for={`${formId}-message`} class="mb-1 block text-sm font-medium text-default">{copy.message}</label>
      <textarea
        id={`${formId}-message`}
        name="message"
        required
        rows={5}
        placeholder={copy.messagePlaceholder}
        class="block w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-sm text-default focus:border-primary focus:outline-none"
      ></textarea>
    </div>

    <label class="flex items-start gap-3 text-sm text-muted">
      <input name="consent" type="checkbox" required class="mt-1 h-4 w-4 rounded border-slate-300 text-primary" />
      <span>{copy.consent}</span>
    </label>

    <button
      type="submit"
      class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90"
    >
      {copy.submit}
    </button>

    <p id={statusId} class="min-h-[1.25rem] text-sm text-muted" aria-live="polite"></p>
  </form>
</div>

<script is:inline define:vars={{ formId, statusId, webhookUrl, copy }}>
  (() => {
    const form = document.getElementById(formId);
    const statusEl = document.getElementById(statusId);

    if (!form || !statusEl) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!(form instanceof HTMLFormElement)) return;
      if (!form.reportValidity()) return;

      const formData = new FormData(form);
      if (formData.get('contactWebsiteTrap')) return;

      if (!webhookUrl) {
        statusEl.textContent = copy.webhookMissing;
        statusEl.className = 'min-h-[1.25rem] text-sm text-amber-700';
        return;
      }

      const submitButton = form.querySelector('button[type="submit"]');
      if (!(submitButton instanceof HTMLButtonElement)) return;

      submitButton.disabled = true;
      statusEl.textContent = copy.sending;
      statusEl.className = 'min-h-[1.25rem] text-sm text-muted';

      const payload = {
        source: String(formData.get('source') || 'website_contact_form'),
        locale: String(formData.get('locale') || ''),
        pagePath: String(formData.get('pagePath') || ''),
        submittedAt: new Date().toISOString(),
        first_name: String(formData.get('first_name') || ''),
        last_name: String(formData.get('last_name') || ''),
        name: `${String(formData.get('first_name') || '')} ${String(formData.get('last_name') || '')}`.trim(),
        email: String(formData.get('email') || ''),
        phone: String(formData.get('phone') || ''),
        company: String(formData.get('company') || ''),
        website: String(formData.get('website') || ''),
        service: String(formData.get('service') || ''),
        message: String(formData.get('message') || ''),
        contact: {
          first_name: String(formData.get('first_name') || ''),
          last_name: String(formData.get('last_name') || ''),
          name: `${String(formData.get('first_name') || '')} ${String(formData.get('last_name') || '')}`.trim(),
          email: String(formData.get('email') || ''),
          phone: String(formData.get('phone') || ''),
          company: String(formData.get('company') || ''),
          website: String(formData.get('website') || ''),
        },
        inquiry: {
          service: String(formData.get('service') || ''),
          message: String(formData.get('message') || ''),
        },
      };

      try {
        const response = await fetch(webhookUrl, {
          method: 'POST',
          mode: 'cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          throw new Error('Primary submit failed');
        }
      } catch {
        try {
          await fetch(webhookUrl, {
            method: 'POST',
            mode: 'no-cors',
            body: JSON.stringify(payload),
          });
        } catch {
          statusEl.textContent = copy.error;
          statusEl.className = 'min-h-[1.25rem] text-sm text-red-700';
          submitButton.disabled = false;
          return;
        }
      }

      form.reset();
      statusEl.textContent = copy.success;
      statusEl.className = 'min-h-[1.25rem] text-sm text-green-700';
      submitButton.disabled = false;
    });
  })();
</script>
