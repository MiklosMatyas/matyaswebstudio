---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import TwentyContactForm from '~/components/ui/TwentyContactForm.astro';

const metadata = {
  title: 'Kontakt',
  description:
    'Kontaktieren Sie uns zu Webentwicklung, Wartung, CRM oder Automatisierung und erhalten Sie ein individuelles Angebot für Ihr Vorhaben.',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Kontakt" title="Lassen Sie uns über Ihr Projekt sprechen" />

  <section id="form" class="relative not-prose scroll-mt-[72px]">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <TwentyContactForm locale="de" />
    </div>
  </section>

  <Features2
    title="Wobei wir helfen können"
    items={[
      {
        title: 'Allgemeine Fragen',
        description: `Wir helfen bei der Einordnung der passenden Leistungen für Ihre Ziele.`,
      },
      {
        title: 'Angebotsanfrage',
        description: 'Sie erhalten ein individuelles Angebot für Webentwicklung, Wartung, CRM oder Automatisierung.',
      },
      {
        title: 'Technische Abstimmung',
        description: 'Wir unterstützen bei Erweiterungen, Fehlerbehebungen und Integrationen bestehender Systeme.',
      },
    ]}
  />
</Layout>
