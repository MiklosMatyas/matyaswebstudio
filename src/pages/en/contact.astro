---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import TwentyContactForm from '~/components/ui/TwentyContactForm.astro';

const metadata = {
  title: 'Contact',
  description:
    'Get in touch about website development, maintenance, CRM, or automation, and request a tailored proposal for your project.',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contact" title="Let’s talk about your project" />

  <section id="form" class="relative not-prose scroll-mt-[72px]">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <TwentyContactForm locale="en" />
    </div>
  </section>

  <Features2
    title="How we can help"
    items={[
      {
        title: 'General questions',
        description: `We help you choose the right service mix and clarify what fits your business goals best.`,
      },
      {
        title: 'Project quote',
        description: 'Request a tailored quote for website development, maintenance, CRM, or automation.',
      },
      {
        title: 'Technical consultation',
        description: 'We can support system extensions, bug fixing, and integration planning for existing platforms.',
      },
    ]}
  />
</Layout>
