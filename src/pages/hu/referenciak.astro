---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';

import { referenciakHero, referenciakItems } from '~/data/referenciak';

const metadata = {
  title: 'Referenciák',
};

const heroBackground =
  typeof referenciakHero.image.src === 'string' ? referenciakHero.image.src : referenciakHero.image.src.src;
---

<Layout metadata={metadata}>
  <Hero
    title={referenciakHero.title}
    subtitle={referenciakHero.subtitle}
    actions={[{ variant: 'primary', text: 'Kapcsolatfelvétel', href: '/hu/kapcsolat' }]}
  >
    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url('${heroBackground}');`}
      >
      </div>
      <div class="absolute inset-0 bg-white/35 dark:bg-slate-900/35"></div>
    </Fragment>
  </Hero>

  {
    referenciakItems.map((item, index) => (
      <Content
        isReversed={index % 2 === 1}
        isAfterContent={index > 0}
        items={item.items}
        contentClass="mb-3 md:mb-4"
        classes={{
          container: `rounded-2xl bg-gradient-to-br from-[#e7e5e6] to-[#efe6e5] border border-slate-300/70 dark:border-slate-600/70 pt-6 md:pt-8 lg:pt-10 pb-3 md:pb-4 lg:pb-5 ${index === 0 ? 'mt-6 md:mt-8 lg:mt-10' : 'mt-4 md:mt-6 lg:mt-8'}`,
        }}
        itemGridClasses={{
          container: 'gap-y-1 md:gap-y-2',
          panel: 'max-w-none items-center',
          title: 'text-base font-normal leading-6 text-muted dark:text-slate-400 ml-2 rtl:ml-0 rtl:mr-2',
          icon: 'flex h-5 w-5 items-center justify-center rounded-full bg-green-600 dark:bg-green-700 text-gray-50 p-0.5',
        }}
      >
        <Fragment slot="content">
          <h3 class="text-xl font-bold tracking-tight dark:text-white sm:text-2xl mb-2">{item.title}</h3>
          <p class="text-base text-muted dark:text-slate-400 mb-5">{item.subtitle}</p>
          <p>{item.description}</p>
        </Fragment>
        <Fragment slot="afterItems">
          {item.url && (
            <p class="text-sm md:text-base">
              <span class="font-medium text-default dark:text-white">Projekt megtekintése:</span>{' '}
              <a
                href={item.url}
                target="_blank"
                rel="nofollow noopener noreferrer"
                class="inline-flex items-center gap-1 text-primary hover:underline break-all"
              >
                {item.url}
                <Icon name="tabler:external-link" class="w-4 h-4 shrink-0" />
              </a>
            </p>
          )}
        </Fragment>
        <Fragment slot="image">
          <Image
            class="mx-auto w-full max-w-xs md:max-w-sm rounded-lg shadow-lg"
            widths={[320, 480, 640]}
            sizes="(max-width: 768px) 320px, 420px"
            layout="constrained"
            {...item.image}
          />
        </Fragment>
      </Content>
    ))
  }

  <CallToAction
    actions={[{ variant: 'primary', text: 'Kérj ajánlatot', href: '/hu/kapcsolat' }]}
    title="Hasonló megoldást szeretnél a vállalkozásodnak?"
    subtitle="Mondd el a céljaidat, és készítünk egy jól felépített, üzletileg hasznos webes megoldást."
  />
</Layout>
