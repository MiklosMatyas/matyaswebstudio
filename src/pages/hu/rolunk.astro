---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';

import aboutHeroBg from '~/assets/images/weboldal-keszites-hero.webp';
import aboutImage from '~/assets/images/matyas_miklos_right-500.webp';

const metadata = {
  title: 'Rólunk',
  description:
    'Ismerd meg a Matyas Web Studio csapatát: több mint 15 év webfejlesztési tapasztalat, üzleti szemléletű kivitelezés és nemzetközi projektmúlt.',
};

const testimonialImageModules = import.meta.glob<ImageMetadata>(
  '~/assets/images/testimonials/*.{webp,jpg,jpeg,png,svg}',
  {
    eager: true,
    import: 'default',
  }
);

const testimonialImages = Object.values(testimonialImageModules);
---

<Layout metadata={metadata}>
  <Hero
    tagline="Együttműködő, üzleti fókuszú fejlesztői szemlélet"
    title="Rólunk"
    subtitle="Tapasztalt, gyors és hatékony fejlesztői csapat vagyunk. Nemcsak a technológiában, hanem az üzleti működésben is otthon vagyunk, így a fejlesztést mindig a vállalkozásod céljaihoz igazítjuk."
    actions={[{ variant: 'primary', text: 'Kapcsolatfelvétel', href: '/hu/kapcsolat' }]}
  >
    <Fragment slot="bg">
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url('${aboutHeroBg.src}');`}
      >
      </div>
      <div class="absolute inset-0 bg-white/35 dark:bg-slate-900/35"></div>
    </Fragment>
  </Hero>

  <Content
    title="Miért minket válassz?"
    subtitle="Kislétszámú csapatunkban a gyorsaság, a rugalmasság és a közvetlen kommunikáció áll a középpontban. Nem egy nagy ügynökség vagyunk, nálunk nem kell több közvetítőn keresztül kommunikálnod – közvetlenül a fejlesztőkkel dolgozol, akik pontosan értik a vállalkozásod igényeit."
    contentAreaClass="md:basis-4/6"
    imageAreaClass="md:basis-2/6"
    classes={{ container: 'pb-0 md:pb-0 lg:pb-1' }}
  >
    <Fragment slot="content">
      <p class="mb-4">
        Több mint másfél évtizede foglalkozom webes megoldásokkal – az utam programozóként indult, majd 2005-től
        webfejlesztőként kezdtem dolgozni. Dolgoztam cégeknél és ügynökségeknél, többek között Írországban is, ahol
        értékes nemzetközi tapasztalatokat szereztem. Az évek során bejártam az informatika számos területét:
        fejlesztettem frontendet és backendet, dolgoztam PHP-vel, JavaScripttel, adatbázisokkal, és mélyen megismertem
        olyan rendszereket, mint a Drupal és a WordPress.
      </p>
      <p class="mb-4">
        Szabadúszóként elsősorban külföldi megrendelők számára dolgoztam, különösen az Egyesült Államokból, Angliából és
        Ausztráliából. Ezekben az együttműködésekben nemcsak fejlesztőként vettem részt, hanem közvetlenül is
        kapcsolatban álltam az ügyfelekkel. Ennek köszönhetően egyre jobban beleláttam a különböző vállalkozások
        működésébe, napi problémáikba és növekedési kihívásaikba.
      </p>
      <p class="mb-4">
        A technikai tudás mellett így természetes módon kezdtem el foglalkozni az online marketing világával is –
        megtanultam, hogyan lehet a fejlesztést és az automatizációt stratégiai eszközként használni ügyfélszerzésre,
        értékesítésre és márkaépítésre.
      </p>
      <p>
        Ma már nemcsak webfejlesztőként tekintek magamra, hanem olyan partnerként, aki a technológiai tudást és az
        üzleti szemléletet ötvözve segít a vállalkozásoknak hatékonyabbá válni, automatizálni, és valódi növekedési
        pályára állni.
      </p>
    </Fragment>

    <Fragment slot="image">
      <figure class="w-full max-w-[500px] ml-auto">
        <img src={aboutImage.src} alt="Matyás Miklós webfejlesztő" class="w-full rounded-lg shadow-lg" loading="lazy" />
        <figcaption class="mt-2 text-sm text-muted dark:text-slate-400 text-center">
          Matyás Miklós / alapító - webfejlesztő
        </figcaption>
      </figure>
    </Fragment>
  </Content>

  <section id="visszajelzesek" class="relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-7xl px-4 md:px-6 pt-0 md:pt-0 lg:pt-0 pb-12 md:pb-16 lg:pb-20 text-default">
      <div class="mb-8 md:mb-10 text-center">
        <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl">Visszajelzések</h2>
        <p class="mt-4 text-muted">Értékelések korábbi ügyfeleimtől az Upwork-ről.</p>
        <a
          class="mt-4 inline-flex items-center gap-1 text-muted hover:text-primary hover:underline"
          href="https://www.upwork.com/freelancers/~0105d6923a730ac73d"
          target="_blank"
          rel="nofollow noopener noreferrer"
        >
          https://www.upwork.com/freelancers/~0105d6923a730ac73d
          <Icon name="tabler:external-link" class="w-4 h-4 shrink-0" />
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {
          testimonialImages.map((image, index) => (
            <figure class="rounded-xl overflow-hidden border border-slate-200/70 dark:border-slate-700/70 bg-slate-50 dark:bg-slate-900">
              <img
                src={image.src}
                alt={`Ügyfél visszajelzés ${index + 1}`}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <CallToAction
    actions={[{ variant: 'primary', text: 'Induljon a projekt', href: '/hu/kapcsolat' }]}
    title="Dolgozzunk együtt a következő fejlesztéseden"
    subtitle="Ha átlátható, üzletileg hasznos és hosszú távon is bővíthető webes megoldást szeretnél, lépj velünk kapcsolatba."
  />
</Layout>
