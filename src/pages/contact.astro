---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Kapcsolat',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Kapcsolat" title="Beszéljünk a projektedről" />

  <ContactUs
    id="form"
    title="Írj nekünk üzenetet"
    subtitle="Röviden írd le a céljaidat, és segítünk megtalálni a legjobb webes megoldást a vállalkozásod számára."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Név',
      },
      {
        type: 'email',
        name: 'email',
        label: 'E-mail',
      },
    ]}
    textarea={{
      label: 'Üzenet',
    }}
    disclaimer={{
      label:
        'Az űrlap elküldésével elfogadod, hogy a megadott adataidat kapcsolatfelvétel céljából kezeljük.',
    }}
    button="Üzenet küldése"
    description="A beérkező üzenetekre jellemzően 1 munkanapon belül válaszolunk."
  />

  <Features2
    title="Miben tudunk segíteni?"
    items={[
      {
        title: 'Általános kérdések',
        description: `Segítünk eligazodni a szolgáltatások között, és közösen pontosítjuk, melyik megoldás illik legjobban az üzleti céljaidhoz.`,
      },
      {
        title: 'Ajánlatkérés',
        description:
          'Weboldal fejlesztésre, karbantartásra, CRM-re vagy automatizálásra kérhetsz egyedi ajánlatot.',
      },
      {
        title: 'Technikai egyeztetés',
        description:
          'Meglévő rendszered bővítéséhez, hibajavításhoz vagy integrációkhoz is tudunk technikai támogatást adni.',
      },
      // {
      //   title: 'Telefon',
      //   description: '+36 30 123 4567',
      //   icon: 'tabler:headset',
      // },
      // {
      //   title: 'E-mail',
      //   description: 'hello@matyaswebstudio.hu',
      //   icon: 'tabler:mail',
      // },
      // {
      //   title: 'Székhely',
      //   description: 'Magyarország',
      //   icon: 'tabler:map-pin',
      // },
    ]}
  />
</Layout>
